# Copy this file to ".env" and fill in your values. ".env" is gitignored.

# Telegram bot credentials (from @BotFather, and the target chat/group ID)
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# USB webcam device indices, one per zone.
#   TWO cameras (one per zone):        CAM_INSIDE_INDEX=0, CAM_OUTSIDE_INDEX=1
#   ONE camera covering both zones:    CAM_INSIDE_INDEX=0, CAM_OUTSIDE_INDEX=0
# With one camera, the device is opened once and the preview is a single pane;
# in ROI edit mode draw two boxes on it — first = INSIDE, second = OUTSIDE.
CAM_INSIDE_INDEX=0
CAM_OUTSIDE_INDEX=1

# Force single-camera dual-zone mode regardless of the indices above (optional).
# SINGLE_CAM=1
